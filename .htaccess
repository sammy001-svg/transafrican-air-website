# DO NOT REMOVE. GENERATED BY NODE.JS APP
PassengerEnabled on
PassengerAppType node
PassengerStartupFile server.js

# Allow Next.js static assets and files to be served directly if they exist
RewriteEngine On
RewriteBase /
RewriteRule ^server.js$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . server.js [L]
